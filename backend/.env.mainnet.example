# Langclaw Sui Walrus mainnet operator template.
# Copy to backend/.env on the demo/operator machine, then fill only the secret
# values. Do not commit the filled .env file.

# --- App/runtime ---
PORT=3002
CORS_ORIGIN=https://langclaw-sui-walrus.vercel.app
OPENAI_API_KEY=<openai_api_key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_AGENT_MODEL=gpt-5.2
LANGCLAW_API_KEY_PEPPER=<random_secret>
LANGCLAW_WALLET_SESSION_SECRET=<random_secret>
LANGCLAW_ALLOW_DEMO_SIGNATURES=false

# --- Supabase persistence ---
SUPABASE_URL=<supabase_project_url>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role_key>

# --- Sui mainnet ---
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_CHAIN_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_CHAIN_EXPLORER_URL=https://suivision.xyz
SUI_AGENT_PRIVATE_KEY=<suiprivkey_or_hex_private_key>
SUI_AGENT_ID=133

# Agent decision proof.
SUI_CHAIN_ENABLED=true
SUI_INTEL_PROOF_ENABLED=true
SUI_LANGCLAW_REGISTRY_PACKAGE_ID=0x7f3578ebe174b0343cd96391b2a1c75d5db4ad82c793650b3950bdb5634192e5
SUI_LANGCLAW_REGISTRY_MODULE=decision_registry
SUI_LANGCLAW_REGISTRY_FUNCTION=record_agent_decision

# Usage vault.
SUI_LANGCLAW_USAGE_VAULT_PACKAGE_ID=0x7f3578ebe174b0343cd96391b2a1c75d5db4ad82c793650b3950bdb5634192e5
SUI_LANGCLAW_USAGE_VAULT_OBJECT_ID=0x816064d45dfe06194a973bce4b38a137365bbd6979c61b0d09435b7a443f3eff
SUI_LANGCLAW_USAGE_VAULT_ADMIN_CAP_OBJECT_ID=0x21314b9534ca673cac1c79d6d1a63b9b0469d684504c974d3e8a5588873e8d09

# --- Walrus mainnet storage ---
# The publisher should be a private relay or local daemon reachable only by the
# backend. The public aggregator is used for independent read-back proof.
WALRUS_PUBLISHER_URL=http://127.0.0.1:31415
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_EPOCHS=5
WALRUS_TIMEOUT_MS=60000

# --- Seal mainnet threshold encryption ---
SEAL_MOCK_MODE=false
SEAL_STRICT_MODE=true
SEAL_PACKAGE_ID=0x7f3578ebe174b0343cd96391b2a1c75d5db4ad82c793650b3950bdb5634192e5
SEAL_POLICY_ID=langclaw-private-memory-mainnet
SEAL_KEY_SERVER_OBJECT_IDS=0x86b608dcb3fcb9c629cfe6d865681977d1decb219a2eb98eb6058b87377feaf3
SEAL_THRESHOLD=1
SEAL_ENCRYPT_TIMEOUT_MS=15000
# Open mode needs no API key. If switching to authenticated providers, use:
# SEAL_KEY_SERVER_CONFIGS_JSON=[{"objectId":"0x...","weight":1,"apiKeyName":"x-api-key","apiKey":"<secret>"}]

# --- Sui memory registry, metadata-only MemoryRecorded events ---
SUI_REGISTRY_ENABLED=true
SUI_REGISTRY_PACKAGE_ID=0x7f3578ebe174b0343cd96391b2a1c75d5db4ad82c793650b3950bdb5634192e5
SUI_REGISTRY_EVENT_PACKAGE_ID=0x7f3578ebe174b0343cd96391b2a1c75d5db4ad82c793650b3950bdb5634192e5
SUI_REGISTRY_MODULE=memory_registry
SUI_REGISTRY_FUNCTION=record_memory
SUI_REGISTRY_PRIVATE_KEY=<suiprivkey_or_hex_private_key>
SUI_REGISTRY_GAS_BUDGET=20000000
SUI_MEMORY_RECALL_FROM_CHAIN=true

# --- MemWal semantic recall ---
MEMWAL_ENABLED=true
MEMWAL_ACCOUNT_ID=<memwal_account_id>
MEMWAL_PRIVATE_KEY=<memwal_private_key>
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
MEMWAL_NAMESPACE=langclaw-private-memory
MEMWAL_ALLOW_PRIVATE_SUMMARY=false
MEMWAL_TOP_K=5
MEMWAL_TIMEOUT_MS=30000

# --- Demo/reviewer path ---
# Turn this on only for pre-linked demo accounts so judges can run research
# without topping up usage credits.
LANGCLAW_ALPHA_ALERTS_ENABLED=true
LANGCLAW_TELEGRAM_BOT_TOKEN=<telegram_bot_token>
LANGCLAW_TELEGRAM_BOT_USERNAME=langclawaibot
