# --- Sui + Walrus private-memory layer (mainnet default) ---
# Everything below runs against local fallbacks with NO credentials:
# Walrus -> local files, Seal -> AES-256-GCM envelope, MemWal -> disabled,
# Sui registry -> disabled, demo signatures allowed.
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
LANGCLAW_LOCAL_STATE_DIR=.langclaw-state
LANGCLAW_ALLOW_DEMO_SIGNATURES=true

# Walrus blob storage (mainnet publisher requires your own authenticated relay;
# leave publisher blank for local-file fallback)
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_EPOCHS=5
WALRUS_TIMEOUT_MS=60000
WALRUS_LOCAL_STORE_DIR=.langclaw-state/walrus

# Seal encryption (mock mode uses the offline AES envelope + owner gate)
SEAL_MOCK_MODE=true
SEAL_POLICY_ID=langclaw-private-memory-mainnet
SEAL_PACKAGE_ID=
SEAL_KEY_SERVER_OBJECT_IDS=
SEAL_THRESHOLD=1
SEAL_ENCRYPTION_KEY=
SEAL_ENCRYPT_TIMEOUT_MS=15000
SEAL_STRICT_MODE=false

# Private memory critical-path timeouts. The main Walrus memory blob uses the
# storage timeout. Optional handoff, read-back, registry, and MemWal steps use
# the ancillary timeout so they cannot block the visible research result.
PRIVATE_MEMORY_STORAGE_TIMEOUT_MS=60000
PRIVATE_MEMORY_ANCILLARY_TIMEOUT_MS=15000

# Sui Move memory registry (public, metadata-only proof). Publish the Move
# package on mainnet, then paste the resulting ids below.
SUI_REGISTRY_ENABLED=false
SUI_REGISTRY_PACKAGE_ID=
SUI_REGISTRY_MODULE=memory_registry
SUI_REGISTRY_FUNCTION=record_memory
SUI_REGISTRY_OBJECT_ID=
SUI_REGISTRY_PRIVATE_KEY=
SUI_REGISTRY_GAS_BUDGET=20000000

# --- Sui on-chain billing / proof / journal (Phase 3) ---
# Add the three new Move modules (decision_registry, trading_journal, usage_vault)
# to the langclaw_memory package, publish/upgrade, then paste the ids below.
# All paths degrade to honest "not configured" until set (offline-safe).
# Shared signer + network (falls back to SUI_RPC_URL / SUI_NETWORK above):
SUI_AGENT_PRIVATE_KEY=
SUI_CHAIN_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_CHAIN_EXPLORER_URL=https://suivision.xyz
SUI_CHAIN_GAS_BUDGET=100000000
SUI_CHAIN_RECEIPT_POLL_ATTEMPTS=12
SUI_CHAIN_RECEIPT_POLL_INTERVAL_MS=3000
# Agent decision proof (decision_registry::record_agent_decision):
SUI_CHAIN_ENABLED=false
SUI_INTEL_PROOF_ENABLED=false
SUI_LANGCLAW_REGISTRY_PACKAGE_ID=
SUI_LANGCLAW_REGISTRY_MODULE=decision_registry
SUI_LANGCLAW_REGISTRY_FUNCTION=record_agent_decision
SUI_AGENT_ID=
# Strategy Lab trading journal (trading_journal::record_strategy_run):
SUI_TRADING_JOURNAL_ENABLED=false
SUI_LANGCLAW_TRADING_JOURNAL_PACKAGE_ID=
SUI_LANGCLAW_TRADING_JOURNAL_MODULE=trading_journal
SUI_LANGCLAW_TRADING_JOURNAL_FUNCTION=record_strategy_run
# Usage credit vault (native SUI deposits -> usage_vault::deposit). OBJECT_ID is
# the shared Vault object created by the module's init on publish; capture it +
# the AdminCap object id from the publish/upgrade output. Billing = SUI (9 dec).
SUI_LANGCLAW_USAGE_VAULT_PACKAGE_ID=
SUI_LANGCLAW_USAGE_VAULT_OBJECT_ID=
SUI_LANGCLAW_USAGE_VAULT_ADMIN_CAP_OBJECT_ID=

# MemWal semantic memory.
MEMWAL_ENABLED=false
MEMWAL_ACCOUNT_ID=
MEMWAL_PRIVATE_KEY=
MEMWAL_SERVER_URL=
MEMWAL_NAMESPACE=langclaw-private-memory
MEMWAL_ALLOW_PRIVATE_SUMMARY=false
MEMWAL_TOP_K=5
MEMWAL_MAX_DISTANCE=
MEMWAL_TIMEOUT_MS=30000

# Sui-native smart-money/holder data (BlockVision Sui Indexer API)
SUI_BLOCKVISION_ENABLED=false
SUI_BLOCKVISION_API_KEY=
SUI_BLOCKVISION_BASE_URL=https://api.blockvision.org/v2/sui
# Representative coin shown when a smart-money query names no token (optional):
SUI_BLOCKVISION_DEFAULT_COINTYPE=

# Optional Sui mainnet analytics RPC for CEX withdrawal fallback rows.
# Defaults to https://fullnode.mainnet.sui.io:443 when unset.
SUI_ANALYTICS_RPC_URL=
SUI_RPC_CEX_ADDRESS_LIMIT=10
